{
  "name": "@nitex/nitex",
  "version": "0.0.0",
  "description": "NiTeX — a Cartesian plane for LaTeX. The language layer of NiTeX Studio.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./nitex.sty": "./nitex.sty"
  },
  "files": [
    "dist",
    "nitex.sty",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@nitex-studio/engine": "workspace:*",
    "@types/node": "^22.19.17",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
