{
  "name": "@open-beamer/engine",
  "version": "0.0.0",
  "description": "Local LaTeX compilation engine for open-beamer (lualatex/xelatex).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "bench:amclean": "node scripts/bench-amclean.mjs",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
