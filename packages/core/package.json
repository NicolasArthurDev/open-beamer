{
  "name": "@open-beamer/core",
  "version": "0.0.0",
  "description": "Dev server and live PDF preview runtime for open-beamer.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "open-beamer": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "src/app",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@open-beamer/engine": "workspace:*",
    "@vitejs/plugin-react": "^4.3.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
